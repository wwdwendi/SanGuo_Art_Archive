# Team archive frontend configuration.
# Replace ARCHIVE_SERVER_HOST with the LAN hostname or IP of the single center API machine.
VITE_ARCHIVE_API_BASE_URL=http://ARCHIVE_SERVER_HOST:8791/api/archive
VITE_SVN_API_BASE_URL=http://ARCHIVE_SERVER_HOST:8791/api/svn

# Keep this on in team use. It prevents saving to, or reading from, a local/default archive by mistake.
VITE_ARCHIVE_REQUIRE_CENTER_API=true
VITE_ARCHIVE_CENTER_API_BASE_URL=http://ARCHIVE_SERVER_HOST:8791/api/archive
VITE_ARCHIVE_REQUIRED_SHARED_ROOT=E:\X28Assets\X28Ref\ArtArchive\data
VITE_ARCHIVE_REQUIRED_DATA_FILE=E:\X28Assets\X28Ref\ArtArchive\data\archive-db.json

# Static fallback is intentionally off by default. Turning it on can show stale/default data.
# VITE_ARCHIVE_ALLOW_STATIC_FALLBACK=false
