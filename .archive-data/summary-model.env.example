# Copy this file to `.archive-data/summary-model.env`, or place the same file
# in the shared archive data root, for example:
# E:\X28Assets\X28Ref\ArtArchive\data\summary-model.env
#
# The same OpenAI-compatible chat completions model is used by:
# - editor auto summary
# - editor category recognition
# - web clip Chinese translation

# Recommended shared aliases for both summary and classification:
ARCHIVE_AI_MODEL_BASE_URL=https://api.example.com/v1
ARCHIVE_AI_MODEL_NAME=your-model-name
ARCHIVE_AI_MODEL_API_KEY=your-api-key
ARCHIVE_AI_MODEL_TIMEOUT_MS=45000

# If your provider gives a full chat completions endpoint, use this instead:
# ARCHIVE_AI_MODEL_URL=https://api.example.com/v1/chat/completions

# Legacy names are still supported:
# ARCHIVE_SUMMARY_MODEL_BASE_URL=https://api.example.com/v1
# ARCHIVE_SUMMARY_MODEL_NAME=your-model-name
# ARCHIVE_SUMMARY_MODEL_API_KEY=your-api-key
